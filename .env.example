# Copia este archivo a `.env` y pega tus llaves de Supabase (Project Settings → API).
# Sin esto, la app funciona 100% local (sin nube).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Notificaciones push (opcional). Llave PÚBLICA VAPID (la privada va en Supabase, no aquí).
# Genérala con:  npx web-push generate-vapid-keys   (ver NOTIFICATIONS.md)
VITE_VAPID_PUBLIC_KEY=
